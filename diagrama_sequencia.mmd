%%{init: {'themeVariables': {
    'noteBkgColor': '#000000',
    'noteTextColor': '#ffffff',
    'noteBorderColor': '#ac841863'
}}}%%
sequenceDiagram
    actor Usuario

    participant TurmaCard as TurmaCard (View)
    participant Navbar as Navbar (View)

    participant App as App (Interface)
    participant useGerenciador as useGerenciador (Interface)
    participant GerenciadorTelas as GerenciadorTelas (Interface)
    participant useMural as useMural (Interface)

    participant UsuarioState as UsuarioState (Modelo)
    participant Turma as Turma (Modelo)
    participant Post as Post (Modelo)
    participant leituraJson as leituraJson (Modelo)

    rect rgb(6, 77, 148)
        Note over Usuario,leituraJson: 1. Inicializacao da aplicacao
        Usuario->>TurmaCard: Acessa NexusClass
        TurmaCard->>App: Renderiza
        App->>useGerenciador: Inicializa hook
        useGerenciador->>UsuarioState: Cria estado inicial
        UsuarioState-->>useGerenciador: usuario inicial
        useGerenciador-->>App: usuario e funcoes
        App->>leituraJson: Carrega dados
        leituraJson-->>App: listaEscolar
        App->>GerenciadorTelas: Passa props
        GerenciadorTelas->>TurmaCard: Renderiza turmas
        TurmaCard-->>Usuario: Exibe lista de turmas
    end

    rect rgb(158, 8, 8)
        Note over Usuario,leituraJson: 2. Inscricao em turma
        Usuario->>TurmaCard: Clica Inscrever-se
        TurmaCard->>App: clickInscrito(key)
        App->>useGerenciador: mudarInscricao(matematica)
        useGerenciador->>UsuarioState: Toggle inscricoes[key]
        UsuarioState-->>useGerenciador: estado atualizado
        useGerenciador-->>App: novo usuario
        App->>GerenciadorTelas: Atualiza props
        GerenciadorTelas->>TurmaCard: Re-renderiza card
        TurmaCard-->>Usuario: Exibe status inscrito
    end

    rect rgb(85, 42, 3)
        Note over Usuario,leituraJson: 3. Navegacao para mural
        Usuario->>TurmaCard: Clica Entrar no Mural
        TurmaCard->>App: clickMural(key)
        App->>useGerenciador: marcarMural(matematica)
        useGerenciador->>UsuarioState: Define acessouOq e chaveMural
        UsuarioState-->>useGerenciador: estado de navegacao
        useGerenciador-->>App: estado atualizado
        App->>GerenciadorTelas: Renderiza mural
        GerenciadorTelas->>leituraJson: Busca turma por key
        leituraJson-->>GerenciadorTelas: Turma encontrada
        GerenciadorTelas->>Navbar: Renderiza cabecalho
        Navbar-->>Usuario: Exibe dados da turma
    end

    rect rgb(87, 3, 41)
        Note over Usuario,leituraJson: 4. Criacao de post
        Usuario->>Navbar: Clica Postar no mural
        Navbar->>useMural: mudarAberturaBox(true)
        useMural-->>Navbar: box aberto
        Navbar-->>Usuario: Exibe modal
        Usuario->>Navbar: Digita e publica
        Navbar->>useMural: handlePublicar()
        useMural->>Post: Cria novo post
        Post-->>useMural: post criado
        useMural->>useMural: Adiciona ao estado
        useMural-->>Navbar: lista de posts atualizada
        Navbar-->>Usuario: Exibe novo post
    end

    rect rgb(33, 4, 97)
        Note over Usuario,leituraJson: 5. Troca de abas no mural
        Usuario->>Navbar: Clica aba Atividades
        Navbar->>useMural: abrirAtividades()
        useMural-->>Navbar: aba atividades ativa
        Navbar-->>Usuario: Exibe atividades
        Usuario->>Navbar: Clica aba Alunos
        Navbar->>useMural: abrirAlunos()
        useMural->>Turma: Consulta alunos
        Turma-->>useMural: lista de alunos
        useMural-->>Navbar: aba alunos ativa
        Navbar-->>Usuario: Exibe alunos
    end

    rect rgb(97, 88, 3)
        Note over Usuario,leituraJson: 6. Volta para principal
        Usuario->>Navbar: Clica Inicio
        Navbar->>App: navegarPara(principal)
        App->>useGerenciador: navegarPara(principal)
        useGerenciador->>UsuarioState: Atualiza acessouOq
        UsuarioState-->>useGerenciador: estado principal
        useGerenciador-->>App: estado atualizado
        App->>GerenciadorTelas: Renderiza principal
        GerenciadorTelas->>TurmaCard: Re-renderiza lista
        TurmaCard-->>Usuario: Exibe tela principal
    end
