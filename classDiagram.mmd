classDiagram
    %% ============================================
    %% BLOCO 1: ESTRUTURAS DE DADOS (INTERFACES)
    %% ============================================

    class TurmaProps {
        <<interface>>
        + materia: string
        + professor: string
        + banners: string
        + alunos: string[]
        + foto_professor: string
        + sala: string
        + turma: string
    }

    class EscolaProps {
        <<interface>>
        + escola: string
        + ano_letivo: int
        + turmas: Record~string, TurmaProps~
    }

    class Post {
        <<interface>>
        + id: string
        + conteudo: string
        + data: string
    }

    class UsuarioState {
        <<interface>>
        + inscricoes: Record~string, boolean~
        + acessouOq: OpcoesTela
        + chaveMural: string
    }

    class PostsState {
        <<interface>>
        + posts: Post[]
        + boxAberto: boolean
        + tipoAmostar: string
    }

    %% ============================================
    %% BLOCO 2: LÓGICA DE NEGÓCIO (HOOKS)
    %% ============================================

    class useGerenciador {
        <<hook>>
        - usuario: UsuarioState
        + mudarInscricao(materia: string): void
        + estaInscrito(materia: string): boolean
        + marcarMural(key: string): void
        + navegarPara(tela: OpcoesTela): void
        + marcarCalendario(): void
        + marcarPesquisa(): void
    }

    class useMural {
        <<hook>>
        - posts: PostsState
        - conteudo: string
        - assunto: string
        + mudarAberturaBox(aberto: boolean): void
        + handlePublicar(): void
        + handleCancelar(): void
        + abrirMural(): void
        + abrirAtividades(): void
        + abrirContato(): void
        + abrirAlunos(): void
    }

    %% ============================================
    %% BLOCO 3: COMPONENTES PRINCIPAIS E UI
    %% ============================================

    class App {
        <<component>>
        - usuario: UsuarioState
        + render(): JSX_Element
    }

    class AppSidebar {
        <<component>>
        - items: MenuItem[]
        + navegarPara: function
        + marcarMural: function
        + render(): JSX_Element
    }

    class Navbar {
        <<component>>
        - notifications: Record~string, boolean~
        + setTheme(theme: string): void
        + render(): JSX_Element
    }

    class GerenciadorTelas {
        <<component>>
        - turmaSelecionada: TurmaProps
        + render(): JSX_Element
    }

    class Mural {
        <<component>>
        - materia: string
        - turma: TurmaProps
        + render(): JSX_Element
    }

    class Calendario {
        <<component>>
        + render(): JSX_Element
    }

    class Mensagens {
        <<component>>
        + render(): JSX_Element
    }

    class Suporte {
        <<component>>
        + render(): JSX_Element
    }

    class TurmaCard {
        <<component>>
        + materia: string
        + inscrito: boolean
        + compacto: boolean
        + clickInscrito(): void
        + clickMural(materia: string): void
        + render(): JSX_Element
    }

    class Pesquisar {
        <<component>>
        - textoPesquisa: string
        - turmasFiltradas: TurmaProps[]
        + render(): JSX_Element
    }

    class BoxMural {
        <<component>>
        + materia: string
        + aberto: boolean
        + onPublicar(): void
        + onClose(): void
        + render(): JSX_Element
    }

    class AtendimentoContato {
        <<component>>
        + professorNome: string
        + mensagem: string
        + onEnviar(): void
        + render(): JSX_Element
    }

    class AlunosTurma {
        <<component>>
        + turma: TurmaProps
        + render(): JSX_Element
    }

    %% ============================================
    %% RELACIONAMENTOS (REGRAS FORMAIS UML)
    %% ============================================

    %% Relações de Agregação e Composição de Dados
    EscolaProps "1" o-- "0..*" TurmaProps : agrega
    PostsState "1" o-- "0..*" Post : contém
    
    %% Dependências de Hooks (Gerenciamento de Estado)
    useGerenciador ..> UsuarioState : gerencia
    useMural ..> PostsState : gerencia
    
    %% Estrutura do App (Composição Forte)
    App *-- Navbar : contém
    App *-- AppSidebar : contém
    App *-- GerenciadorTelas : contém
    App ..> useGerenciador : utiliza hook

    %% Fluxo do Gerenciador de Telas
    GerenciadorTelas "1" --> "0..*" TurmaCard : instancia
    GerenciadorTelas "1" --> "0..1" Mural : exibe
    GerenciadorTelas "1" --> "0..1" Pesquisar : exibe
    GerenciadorTelas "1" --> "0..1" Calendario : exibe
    GerenciadorTelas "1" --> "0..1" Mensagens : exibe
    GerenciadorTelas "1" --> "0..1" Suporte : exibe
    GerenciadorTelas ..> EscolaProps : consome dados

    %% Composição do Mural
    Mural *-- BoxMural : possui
    Mural *-- AtendimentoContato : possui
    Mural *-- AlunosTurma : possui
    Mural ..> useMural : utiliza hook

    %% Associações de Navegação e Pesquisa
    Pesquisar "1" --> "0..*" TurmaCard : filtra e renderiza
    AppSidebar ..> TurmaProps : referencia para lista inscritas