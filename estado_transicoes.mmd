stateDiagram-v2
    [*] --> Principal: App Inicializa

    state Principal {
        [*] --> ListandoTurmas
        ListandoTurmas --> TurmaCardSelecionada: clica card
        TurmaCardSelecionada --> [*]
    }

    state Mural {
        [*] --> VisualizandoMural
        VisualizandoMural --> CriarPost: clica Postar
        CriarPost --> VisualizandoMural: publica ou cancela
        VisualizandoMural --> AbaMural: aba mural
        VisualizandoMural --> AbaAtividades: aba atividades
        VisualizandoMural --> AbaAlunos: aba alunos
        VisualizandoMural --> AbaContato: aba contato
        AbaMural --> [*]
        AbaAtividades --> [*]
        AbaAlunos --> [*]
        AbaContato --> [*]
    }

    state Pesquisar {
        [*] --> BuscandoTurmas
        BuscandoTurmas --> ResultadosPesquisa: busca ok
        ResultadosPesquisa --> [*]
    }

    state Calendario {
        [*] --> ExibindoCalendario
        ExibindoCalendario --> VisualizandoEvento: seleciona evento
        VisualizandoEvento --> [*]
    }

    state Mensagens {
        [*] --> ListaMensagens
        ListaMensagens --> ConversaAberta: clica conversa
        ConversaAberta --> EnviandoMensagem: envia
        EnviandoMensagem --> [*]
    }

    state Suporte {
        [*] --> TigresoEXE
        TigresoEXE --> ChatTigreso: interage
        ChatTigreso --> [*]
    }

    Principal --> Pesquisar: navegarPara pesquisar
    Principal --> Calendario: navegarPara calendario
    Principal --> Mensagens: navegarPara mensagens
    Principal --> Suporte: navegarPara suporte
    Principal --> Mural: marcarMural key

    Pesquisar --> Principal: voltarPrincipal
    Calendario --> Principal: voltar
    Mensagens --> Principal: voltar
    Suporte --> Principal: voltar
    Mural --> Principal: voltar ou sair

    Pesquisar --> Mural: clica card
    Calendario --> Mensagens: navegarPara mensagens
    Mensagens --> Suporte: navegarPara suporte